NODE_ENV=production
PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aloo_smm
JWT_SECRET=replace-this-with-a-long-random-secret-at-least-32-characters
JWT_EXPIRES_IN=12h
CORS_ORIGIN=http://localhost:5173
ADMIN_FULL_NAME=Aloo Admin
ADMIN_LOGIN=admin
ADMIN_PHONE=998901234567
ADMIN_PASSWORD=123456

# Optional AI provider. Without this key the built-in local SMM assistant works.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini

# Optional Web Push
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@aloosmm.uz
